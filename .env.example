# HedgeDoc Domain and URL settings
CMD_DOMAIN=localhost
HEDGEDOC_PUBLIC_URL=http://localhost:8210
MCP_PUBLIC_URL=http://localhost:8211

# Security (Change these to secure random strings)
CMD_SESSION_SECRET=change-me-to-a-random-secret
MCP_API_KEY=change-me-to-a-random-key

# OAuth2 Settings
CMD_OAUTH2_PROVIDERNAME=MyProvider
CMD_OAUTH2_CLIENT_ID=your-client-id
CMD_OAUTH2_CLIENT_SECRET=your-client-secret
# Browser-facing authorization URL
CMD_OAUTH2_AUTHORIZATION_URL=http://localhost:8207/authorize
# Server-to-server URLs (must be reachable from inside the container)
CMD_OAUTH2_TOKEN_URL=http://host.docker.internal:8207/token
CMD_OAUTH2_USER_PROFILE_URL=http://host.docker.internal:8207/userinfo
